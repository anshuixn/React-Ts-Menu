# ============================================================
# AuraSpice: Required Environment Variables
# Copy to .env.local and fill in your real values.
# ============================================================

# --- Client-side (VITE_ prefix — exposed to the browser bundle) ---
# Supabase project URL from Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase public anon key (safe for client-side use)
VITE_SUPABASE_ANON_KEY=your-public-anon-key
# Your production URL (used for og:url meta tag)
VITE_PUBLIC_URL=https://your-production-domain.com

# --- Server-side only (NEVER prefixed with VITE_) ---
# Same Supabase URL, needed by Vercel serverless functions
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key (full DB access — NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
# Secret for signing JWT staff session tokens (min 32 chars recommended)
JWT_SECRET=replace-with-a-long-random-secret
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com
