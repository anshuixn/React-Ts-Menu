    "bcrypt": "^6.0.0",
    "canvas-confetti": "^1.9.4",
    "cookie": "^1.1.1",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.11.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "vite-plugin-pwa": "^1.3.0",
