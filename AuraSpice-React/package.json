{
  "name": "auraspice-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vercel dev --listen 5174",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
